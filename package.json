{
  "name": "rdf-data-factory",
  "version": "2.0.2",
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e",
  "description": "A TypeScript/JavaScript implementation of the RDF/JS data factory.",
  "typings": "index",
  "author": "Ruben Taelman <rubensworks@gmail.com>",
  "license": "MIT",
  "funding": {
    "type": "individual",
    "url": "https://github.com/sponsors/rubensworks/"
  },
  "homepage": "https://github.com/rubensworks/rdf-data-factory.js#readme",
  "repository": "git@github.com:rubensworks/rdf-data-factory.js.git",
  "bugs": {
    "url": "https://github.com/rubensworks/rdf-data-factory.js/issues"
  },
  "keywords": [
    "rdf",
    "rdfjs",
    "data factory",
    "factory",
    "data model",
    "rdf terms"
  ],
  "main": "index.js",
  "files": [
    "index.d.ts",
    "index.js",
    "index.js.map",
    "lib/**/*.d.ts",
    "lib/**/*.js",
    "lib/**/*.js.map"
  ],
  "scripts": {
    "test": "jest ${1}",
    "test-watch": "jest ${1} --watch",
    "coveralls": "jest --coverage && cat ./coverage/lcov.info | coveralls",
    "lint": "ESLINT_USE_FLAT_CONFIG=true eslint .",
    "build": "tsc",
    "validate": "npm ls",
    "prepare": "npm run build",
    "version": "manual-git-changelog onversion"
  },
  "dependencies": {
    "@rdfjs/types": "^2.0.0"
  },
  "pre-commit": [
    "build",
    "lint",
    "test"
  ],
  "devDependencies": {
    "@rubensworks/eslint-config": "^3.0.0",
    "@types/jest": "^30.0.0",
    "coveralls": "^3.0.0",
    "eslint": "^8.56.0",
    "jest": "^30.0.0",
    "jest-rdf": "^2.0.0",
    "manual-git-changelog": "^1.0.0",
    "pre-commit": "^2.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^6.0.0"
  },
  "jest": {
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "transformIgnorePatterns": [
      "[/\\\\]node_modules[/\\\\].+\\.(js|jsx)$"
    ],
    "testRegex": "(/test/.*|(\\.|/)(test|spec))\\.ts$",
    "moduleFileExtensions": [
      "ts",
      "js"
    ],
    "collectCoverage": true,
    "coverageThreshold": {
      "global": {
        "branches": 100,
        "functions": 100,
        "lines": 100,
        "statements": 100
      }
    }
  }
}
